DATABASE_URL="postgresql://postgres:password@localhost:5432/pixel_digital?schema=public"
# Local / prisma push from PC: External URL + ?sslmode=require
# Example: postgresql://user:pass@dpg-xxxxx-a.oregon-postgres.render.com/dbname?sslmode=require
# Render web service only: Internal URL (short host, no .oregon-postgres.render.com)
# Example: postgresql://user:pass@dpg-xxxxx-a/dbname
PORT=4000
JWT_SECRET="change-this-to-a-long-random-secret"
ADMIN_PHONE="9999999999"
ADMIN_PASSWORD="1234"
ADMIN_EMAIL="admin@pixeldigital.com"
# --- Supabase Storage (recommended on Render Free — artwork survives redeploy) ---
# 1. supabase.com → New project
# 2. Storage → New bucket → name: artwork → Private
# 3. Settings → API → copy Project URL + service_role key (secret)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="artwork"
# If SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are set, uploads go to Supabase.
# If not set, files save to UPLOAD_DIR on local disk (lost on Render Free redeploy).

# Local folder fallback when Supabase is not configured:
UPLOAD_DIR="./uploads"
# Resolved to an absolute path from the backend folder at runtime.
FRONTEND_URL="http://localhost:3000"
# Production (Render): your Vercel URL, e.g. https://your-app.vercel.app
# Multiple origins: https://your-app.vercel.app,https://yourdomain.com
ALLOWED_ORIGINS=""
FIREBASE_PROJECT_ID="pixeldigital-644fc"
FIREBASE_SERVICE_ACCOUNT_JSON=""
# Option A: paste minified one-line JSON from Firebase service account key file
# Option B (easier on Render): base64-encode the JSON file → FIREBASE_SERVICE_ACCOUNT_BASE64
# PowerShell: [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes((Get-Content .\key.json -Raw)))
FIREBASE_SERVICE_ACCOUNT_BASE64=""
